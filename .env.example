# Copy to ".env" and fill values as needed.

# Optional for Phase 0; required once you integrate an LLM.
LLM_PROVIDER=openai
LLM_API_KEY=

# Groq (Phase 4)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Dataset config (used in Phase 1+)
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
HF_DATASET_SPLIT=train

# App behavior
LOG_LEVEL=INFO

# Phase 7 API — comma-separated browser origins allowed for CORS (plus regex for localhost:any-port by default)
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Production: add your Vercel URL, e.g. https://your-app.vercel.app
# Set to 1 to lock down to API_CORS_ORIGINS only (no localhost:any-port regex)
# API_CORS_DISABLE_LOCALHOST_REGEX=0

# Production dataset path (Railway volume mount at /data). Default on Railway: /data/processed/restaurants.parquet
# ZOMATO_PROCESSED_DATASET=/data/processed/restaurants.parquet

# Railway: run Phase 1 ingest on startup if Parquet is missing (first deploy ~1–4 min; prefer a volume)
# ZOMATO_AUTO_INGEST_IF_MISSING=0


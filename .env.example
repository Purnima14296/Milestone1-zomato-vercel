# Copy to ".env" and fill values as needed.

# Optional for Phase 0; required once you integrate an LLM.
LLM_PROVIDER=openai
LLM_API_KEY=

# Groq (Phase 4)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Dataset config (used in Phase 1+)
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
HF_DATASET_SPLIT=train

# App behavior
LOG_LEVEL=INFO

# Phase 7 API — comma-separated browser origins (localhost defaults for dev)
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Production on Railway: also add your Vercel URL, e.g. https://your-app.vercel.app
# Railway auto-allows *.vercel.app when API_CORS_ALLOW_VERCEL=1 (default)
# API_CORS_ALLOW_VERCEL=1
# API_CORS_DISABLE_LOCALHOST_REGEX=1

# Production dataset path (Railway volume mount at /data)
# ZOMATO_PROCESSED_DATASET=/data/processed/restaurants.parquet

# Run Phase 1 ingest on API startup if Parquet is missing
# ZOMATO_AUTO_INGEST_IF_MISSING=0

# Skip dataset ingest in scripts/railway_build.sh when using a Railway volume
# RAILWAY_SKIP_DATASET_INGEST=1
